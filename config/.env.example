# Local dev — copy to .env in this directory.

# Service
ENVIRONMENT=development
SERVICE_NAME=finance
PORT=3006
LOG_LEVEL=info

# Database / cache
DATABASE_URL=postgresql://svc_finance:iag_finance_dev@localhost:5432/iag_platform?sslmode=disable
REDIS_URL=redis://127.0.0.1:6379/1
AUTO_MIGRATE=true
SEED_ON_STARTUP=true

# Platform auth (hard cutover: every inbound request must carry a verifiable Bearer
# with aud=iag.finance; AUTH_MODE and GATEWAY_INTERNAL_SECRET no longer exist).
JWT_ISSUER=http://localhost:3001
JWKS_URL=http://localhost:3001/.well-known/jwks.json
AUDIENCE=iag.finance

# Outbound service-account credentials
SERVICE_CLIENT_ID=iag-finance
SERVICE_CLIENT_SECRET=dev-finance-secret-bootstrap
AUTH_TOKEN_URL=http://localhost:3001/oauth/token

# CORS
CORS_ALLOW_ORIGIN=http://localhost:3000,http://localhost:5173

# Kafka — iag.finance topic produce + consume
ENABLE_CONSUMER=false
KAFKA_BROKERS=localhost:19092
KAFKA_CLIENT_ID=finance
KAFKA_GROUP_ID=iag.finance.ledger
KAFKA_FINANCE_TOPIC=iag.finance
KAFKA_DLQ_TOPIC=iag.finance.dlq

# Optional tuning
# SHUTDOWN_TIMEOUT_SECONDS=15
