# Production — behind API gateway (AUTH_MODE=gateway).
ENVIRONMENT=production
SERVICE_NAME=finance
PORT=3006
LOG_LEVEL=info

DATABASE_URL=postgresql://svc_finance:PASSWORD@HOST:5432/iag_platform?sslmode=require

AUTH_MODE=gateway
GATEWAY_INTERNAL_SECRET=change-me-in-production-min-16-chars
JWT_ISSUER=https://auth.example.com
JWKS_URL=https://auth.example.com/.well-known/jwks.json

REDIS_URL=rediss://redis.example.com:6379/1
AUTO_MIGRATE=true
SEED_ON_STARTUP=false
ACCOUNTS_URL=http://accounts:3005
