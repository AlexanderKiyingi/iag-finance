# Production — behind API gateway. Copy to Railway env vars.

ENVIRONMENT=production
SERVICE_NAME=finance
PORT=3006
LOG_LEVEL=info

DATABASE_URL=postgresql://svc_finance:PASSWORD@HOST:5432/iag_platform?sslmode=require&options=-c%20search_path%3Dfinance

REDIS_URL=rediss://redis.example.com:6379/1
AUTO_MIGRATE=true
SEED_ON_STARTUP=false

# Platform auth — use the public auth service URL (not *.railway.internal).
JWT_ISSUER=https://iag-authentication-production.up.railway.app
JWKS_URL=https://iag-authentication-production.up.railway.app/.well-known/jwks.json
AUDIENCE=iag.finance

SERVICE_CLIENT_ID=iag-finance
SERVICE_CLIENT_SECRET=change-me-min-16-chars
AUTH_TOKEN_URL=https://iag-authentication-production.up.railway.app/oauth/token

CORS_ALLOW_ORIGIN=https://your-spa.example.com

ENABLE_CONSUMER=true
ENABLE_EVENT_PUBLISH=true
KAFKA_BROKERS=your-kafka:9092
KAFKA_CLIENT_ID=finance
KAFKA_GROUP_ID=iag.finance.ledger
KAFKA_FINANCE_TOPIC=iag.finance
KAFKA_DLQ_TOPIC=iag.finance.dlq
