PORT=8082
DATA_PATH=data/finance-state.json

# Optional production stack (docker-compose up -d)
# DATABASE_URL=postgres://fin:fin@localhost:5434/finance?sslmode=disable
# REDIS_URL=redis://localhost:6381/0

# JWT (enables Bearer auth when JWT_SECRET is set)
# JWT_SECRET=change-me-in-production
# JWT_REQUIRED=false
# JWT_ACCESS_TTL_MINUTES=15
# JWT_REFRESH_TTL_DAYS=7

# CORS (Next.js dev server)
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# RATE_LIMIT_PER_MINUTE=300
# ALLOW_DEMO_RESET=true
# GO_ENV=development

READ_TIMEOUT_SECONDS=15
WRITE_TIMEOUT_SECONDS=15
SHUTDOWN_TIMEOUT_SECONDS=10
