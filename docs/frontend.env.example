# Finance Next.js app — copy to your frontend repo as .env.local
# Guide: docs/FRONTEND_INTEGRATION.md
#
# All browser calls go through iag-api-gateway (never the finance service port).

# --- Local (docker compose / pnpm infra:up) ---
NEXT_PUBLIC_GATEWAY_ORIGIN=http://localhost:8080
NEXT_PUBLIC_AUTH_API_URL=http://localhost:8080/api/v1/authentication
NEXT_PUBLIC_FINANCE_API_URL=http://localhost:8080/api/v1/finance/v1

# Optional — vendor portal apps also need procurement/SCM portal URLs; see SCM guide.
# NEXT_PUBLIC_PROCUREMENT_API_URL=http://localhost:8080/api/v1/procurement/api/v1
# NEXT_PUBLIC_SCM_API_URL=http://localhost:8080/api/v1/supply-chain/api/v1

# --- Production (Railway) — uncomment and replace gateway host ---
# NEXT_PUBLIC_GATEWAY_ORIGIN=https://iag-api-gateway-production.up.railway.app
# NEXT_PUBLIC_AUTH_API_URL=https://iag-api-gateway-production.up.railway.app/api/v1/authentication
# NEXT_PUBLIC_FINANCE_API_URL=https://iag-api-gateway-production.up.railway.app/api/v1/finance/v1

# CORS: add this app's origin to finance CORS_ALLOW_ORIGIN and gateway CORS_ALLOWED_ORIGINS.
# JWT audiences required after login: iag.gateway, iag.finance
# Gateway permission: platform.access_finance (superadmin bypasses)
