# Local development — copy to .env in this directory (go run ./cmd/server)
# Production template: config/.env.production.example

# Service
ENVIRONMENT=development
SERVICE_NAME=finance
PORT=3006
LOG_LEVEL=info

# Database / cache
# Local cluster (scripts/start-local-iag-postgres.ps1): port 5434
# Docker compose stack: port 5432
DATABASE_URL=postgresql://svc_finance:iag_finance_dev@127.0.0.1:5434/iag_platform?sslmode=disable
REDIS_URL=redis://127.0.0.1:6379/1
AUTO_MIGRATE=true
SEED_ON_STARTUP=true

# Platform auth — hard cutover: every inbound request must carry a Bearer JWT with
# aud=iag.finance. AUTH_MODE and GATEWAY_INTERNAL_SECRET no longer exist.
JWT_ISSUER=http://localhost:3001
JWKS_URL=http://127.0.0.1:3001/.well-known/jwks.json
AUDIENCE=iag.finance

# Outbound service-account credentials (permission registration + outbound calls)
SERVICE_CLIENT_ID=iag-finance
SERVICE_CLIENT_SECRET=dev-finance-secret-bootstrap
AUTH_TOKEN_URL=http://127.0.0.1:3001/oauth/token

# CORS (comma-separated browser origins)
CORS_ALLOW_ORIGIN=http://localhost:3000,http://localhost:5173

# Kafka — produces on iag.finance; consumer also subscribes to iag.fleet when enabled
ENABLE_CONSUMER=false
ENABLE_EVENT_PUBLISH=true
KAFKA_BROKERS=localhost:19092
KAFKA_CLIENT_ID=finance
KAFKA_GROUP_ID=iag.finance.ledger
KAFKA_FINANCE_TOPIC=iag.finance
KAFKA_SUPPLY_CHAIN_TOPIC=iag.supply-chain
KAFKA_DLQ_TOPIC=iag.finance.dlq

# Optional tuning
# SHUTDOWN_TIMEOUT_SECONDS=15

# OpenTelemetry — empty disables OTel
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
